# Postgres connection string (Neon). On Vercel use the POOLED endpoint.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Shared secret for admin endpoints (seed, canaries, payout approval) and the
# requester job-submission endpoint. Sent as header `X-Admin-Token: <token>`.
ADMIN_TOKEN="change-me-dev-token"

# Secret to sign chatbot-user session cookies (use a long random string)
JWT_SECRET="change-me-long-random-string"
